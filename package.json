{
  "name": "sequent",
  "version": "1.0.0",
  "private": true,
  "description": "Sequent \u2014 Comic reader with CBR, CBZ, and PDF support",
  "scripts": {
    "dev:backend": "pnpm --filter backend dev",
    "dev:frontend": "pnpm --filter frontend dev",
    "dev": "bash scripts/setup.sh && pnpm install && pnpm run --parallel dev:backend dev:frontend",
    "build:backend": "pnpm --filter backend build",
    "build:frontend": "pnpm --filter frontend build",
    "build": "pnpm build:backend && pnpm build:frontend",
    "seed": "pnpm --filter backend seed",
    "test": "pnpm --filter backend test",
    "setup": "bash scripts/setup.sh"
  },
  "engines": {
    "node": ">=20.11.0"
  }
}
